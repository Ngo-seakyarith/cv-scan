# Neon direct URL for Prisma migrations
DIRECT_DATABASE_URL="postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/dbname?sslmode=require"

GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

OPENROUTER_API_KEY=""
OPENROUTER_MODEL="openai/gpt-4o-mini"